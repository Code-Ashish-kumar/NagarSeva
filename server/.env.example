PORT=5000
DATABASE_URL=postgresql://nagarseva_user:nagarseva_dev_pass@localhost:5432/nagarseva
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-here
JWT_REFRESH_SECRET=your-refresh-secret-key-different-from-above
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# Email (for OTP) — use Gmail App Password or Mailtrap for dev
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
SMTP_FROM=noreply@nagarseva.in

# OTP
OTP_EXPIRY_MINUTES=10
